<policies>
    <inbound>
        <base />
        <cache-lookup caching-type="prefer-external" downstream-caching-type="public" vary-by-developer="false" vary-by-developer-groups="false">
            <vary-by-header>Accept</vary-by-header>
        </cache-lookup>
        <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: Access token is missing">
            <openid-config url="https://login.microsoftonline.com/dca398af-a48c-4d63-bdbd-4fa72a364d97/.well-known/openid-configuration" />
        </validate-jwt>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
        <!-- Store all responses as cached elements for 10 minutes -->
        <cache-store duration="600" />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>